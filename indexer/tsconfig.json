{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "isolatedModules": true,
        "allowImportingTsExtensions": true,
        "jsx": "preserve",
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "ponder.config.ts", "ponder.schema.ts", "*.ts"]
}
