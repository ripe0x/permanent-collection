# --- Required for data pipeline + contracts ---
# Archive-node-capable mainnet RPC (Alchemy/Infura/Quicknode/your own node).
# For day-to-day forge test runs with a warm cache (see FORK_BLOCK below),
# this can be a free public RPC like https://ethereum-rpc.publicnode.com.
MAINNET_RPC_URL=

# Pin Foundry's mainnet fork to a specific block so the per-block RPC cache
# at ~/.foundry/cache/rpc/mainnet/<block> compounds across runs. With
# FORK_BLOCK set, the first run populates the cache (needs archive RPC);
# every subsequent run hits the cache and spends ~zero upstream CU.
# Leave unset to default to fork-at-HEAD. See docs/CACHE_WARMUP.md.
FORK_BLOCK=25133816

# Deterministic fuzz seed. Pairs with FORK_BLOCK so that Foundry's fuzz
# tests (`testFuzz_*`) generate the same inputs every run, letting their
# RPC reads land in the same cache slots. Without this, every fuzz run
# picks new random inputs and the cache can't predict them.
# (Note: Foundry invariant tests don't expose a deterministic-seed knob,
# so the ~12 invariant tests still need archive RPC. See CACHE_WARMUP.md.)
FOUNDRY_FUZZ_SEED=0x1234

# Deployer key (no funds needed for fork). Required only for actual mainnet deploy.
PRIVATE_KEY=

# Optional: contract verification on deploy
ETHERSCAN_API_KEY=

# --- Frontend (NEXT_PUBLIC_*) ---
# Written by `pnpm deploy:fork`; one set per chain id (1 = mainnet, also used for fork).
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://etherscan.io

# (No NEXT_PUBLIC_DEFAULT_REFERRER here — see DEFAULT_REFERRER below,
#  which is the server-only equivalent surfaced via /api/config so the
#  operator can change the address without a frontend rebuild.)

# --- Frontend RPC (server-only — no NEXT_PUBLIC_ prefix) ---
# Browser reads route through the same-origin `/api/rpc` proxy
# (`app/app/api/rpc/route.ts`) so paid API keys never ship in the
# client bundle. Set `RPC_URL` to the upstream node — paid
# Alchemy/Infura for mainnet, or `http://127.0.0.1:8545` for an
# anvil fork. `RPC_URL_FALLBACK` is optional and only used by
# server-side reads in `lib/data/live.ts`.
RPC_URL=http://127.0.0.1:8545
RPC_URL_FALLBACK=

# Default referrer for swaps performed through this UI when the visitor
# has no `?ref=0x...` URL parameter AND no prior stored referrer.
# Surfaced to the browser via `/api/config` (server-side env var — NOT
# NEXT_PUBLIC, so the address can be changed by updating this env var on
# the hosting platform WITHOUT a frontend rebuild). The hook is bounded
# to 250 bps (0.25% of volume) per swap and ignores attribution until
# pc.acquisitionCount() > 0, so launch-window snipers can't sneak in.
#
# Set to the protocol-operator's treasury wallet to capture the referral
# slice on direct-load swaps. URL-attributed swaps (`?ref=0xfriend`)
# still override. Leave unset to disable the fallback entirely.
DEFAULT_REFERRER=

# ── Vanity referral slugs (`/r/<slug>`, operator-curated) ──────────────
# Slugs are COSMETIC: `/r/<slug>` 307-redirects to `/trade?ref=<address>`,
# and on-chain attribution always uses the resolved address. There is no
# public claiming — the operator curates the set.
#
# Bearer token gating writes to POST /api/referral-alias (set/remove). When
# unset, writes are disabled (the GET reverse-lookup still works). Server-
# only; never NEXT_PUBLIC. Use a long random string.
REFERRAL_ADMIN_TOKEN=
# Optional deploy-time seed: a flat JSON map {"slug":"0xaddress"} merged on
# top of the committed app/config/referral-aliases.json (Netlify Blobs, the
# live operator surface, overrides both). Lets a deploy ship partner slugs
# with no rebuild — same spirit as DEFAULT_REFERRER. Example:
#   REFERRAL_ALIASES_JSON={"punkstrategy":"0x41c3BD8A36f8fE9Bb77900ca02400b32BB35A6A4"}
REFERRAL_ALIASES_JSON=

# Per-IP rate limit on /api/rpc (requests per minute per client IP).
# Defaults to 300, which comfortably covers a normal page-loaded user.
# Set to `0` to disable. Skipped automatically when RPC_URL points at a
# local anvil node, so dev's high-burst auto-unstick path is unaffected.
RPC_RATE_LIMIT_PER_MIN=300

# External mainnet contracts (do not change for mainnet/fork)
NEXT_PUBLIC_PUNKS_MARKET_ADDRESS=0xb47e3cd837dDF8e4c57F05d70Ab865de6e193BBB
NEXT_PUBLIC_PUNKS_DATA_ADDRESS=0x9cF9C8eA737A7d5157d3F4282aCe30880a7A117C
NEXT_PUBLIC_V4_POOL_MANAGER=0x000000000004444c5dC75cB358380D2e3dE08A90
NEXT_PUBLIC_V4_POSITION_MANAGER=0xbD216513d74C8cf14cf4747E6AaA6420FF64ee9e
NEXT_PUBLIC_V4_UNIVERSAL_ROUTER=0x66a9893cC07D91D95644AEDD05D03f95e1dBA8Af

# Protocol contract addresses (filled in by deploy script).
# The 111 token is `NewMaterialToken` deployed by the artcoins factory.
# The launcher/hook/traitIndex env vars are obsolete — artcoins
# provides the hook + LP infrastructure, and trait data lives at the
# canonical PunksData address (NEXT_PUBLIC_PUNKS_DATA_ADDRESS).
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_AP_ADAPTER_ADDRESS=
NEXT_PUBLIC_ACQUISITION_POOL_ADDRESS=
NEXT_PUBLIC_CLAIM_MANAGER_ADDRESS=
NEXT_PUBLIC_PERMANENT_COLLECTION_ADDRESS=
NEXT_PUBLIC_BID_MANAGER_ADDRESS=
NEXT_PUBLIC_PROTOCOL_ADMIN_ADDRESS=
NEXT_PUBLIC_PERMANENT_COLLECTION_RENDERER_ADDRESS=
NEXT_PUBLIC_DEPLOY_BLOCK=

# --- Runtime address overrides (PC_*) — flip launch with NO rebuild ---
# Every protocol NEXT_PUBLIC_*_ADDRESS above also has a server-only PC_-prefixed
# twin (the same name minus the NEXT_PUBLIC_ prefix). The root layout reads the
# PC_* vars per request and injects them into the page as
# window.__PC_RUNTIME_CONFIG__, so client components resolve addresses at
# RUNTIME instead of from values inlined into the JS bundle at build time.
#
# Why it matters: a PC_* value overrides its NEXT_PUBLIC_* twin and takes effect
# on the next request after a Node-runtime restart (sub-second on Vercel/Netlify)
# — NO client rebuild. To launch the protocol without a rebuild, deploy the site
# with the addresses UNSET (the app renders "not launched yet" with honest
# zeros), then set the PC_* vars at launch; isProtocolLive() flips the moment
# PC_TOKEN_ADDRESS is a real, non-zero address. An unset/empty PC_* falls back to
# its NEXT_PUBLIC_* twin, so existing build-time setups keep working unchanged.
# (The override prefix is literally PC_ + the NEXT_PUBLIC base name, so the
#  optional pcSwapContext twin is the awkward-but-harmless PC_PC_SWAP_CONTEXT_ADDRESS.)
#
# PC_TOKEN_ADDRESS=
# PC_PERMANENT_COLLECTION_ADDRESS=
# PC_PATRON_ADDRESS=
# PC_RETURN_AUCTION_MODULE_ADDRESS=
# PC_PUNK_VAULT_ADDRESS=
# PC_BUYBACK_BURNER_ADDRESS=
# PC_LIVE_BID_ADAPTER_ADDRESS=
# PC_VAULT_BURN_POOL_ADDRESS=
# PC_PROTOCOL_FEE_PHASE_ADAPTER_ADDRESS=
# PC_REFERRAL_PAYOUT_ADDRESS=
# PC_TITLE_AUCTION_ADDRESS=
# PC_RENDERER_ADDRESS=
# PC_PROTOCOL_ADMIN_ADDRESS=
# PC_ARTCOINS_HOOK_ADDRESS=
#
# Post-launch static switch. While unset, the client confirms "live" by checking
# the token has bytecode on-chain (one cached eth_getCode per visitor) — so a
# pre-baked address auto-flips live the moment the contracts deploy, and contract
# links stay inert until then. Once the launch has settled, set
# PC_PROTOCOL_LIVE=true to skip that check entirely (pure address-based, ZERO
# RPC). The code check is only needed during the pre-launch → live window.
# PC_PROTOCOL_LIVE=
